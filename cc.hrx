# -----------------
# ✅ Option 2 — Use “Custom Hot Corners Extended” or “Custom Shortcuts” + a script
# 
# You can bind a key to a script that forces GNOME to create a workspace.
# 
# Example script to create a workspace:
# Code
# 
# #!/bin/bash
# gdbus call --session \
#   --dest org.gnome.Shell \
#   --object-path /org/gnome/Shell \
#   --method org.gnome.Shell.Eval \
#   "global.workspace_manager.append_new_workspace();"
# 
# Bind it to Super+Ctrl+D.
# 
# To close the current workspace:
# Code
# 
# #!/bin/bash
# gdbus call --session \
#   --dest org.gnome.Shell \
#   --object-path /org/gnome/Shell \
#   --method org.gnome.Shell.Eval \
#   "global.workspace_manager.remove_workspace(global.workspace_manager.get_active_workspace());"
# 
# Bind it to Super+Ctrl+F4.
# 
# This works but requires scripting.









