==> performant-elementReady.js <==

// example cb:
function checkMatchFast(el, { selector, tagName, className, id }) {
	if (id != null && el.id === id) return true; // note: no .toLowerCase to improve performance
	if (tagName != null && el.tagName === tagName) return true;
	if (className != null && el.classList.contains(className)) return true;
	if (selector != null && el.matches(selector)) return true;

	return false;
}

function* walkElements(root) {
	const walker = document.createTreeWalker(
		root,
		NodeFilter.SHOW_ELEMENT,
		null
	);

	// Start at the root itself
	let node = walker.currentNode;
	yield node;

	// Walk the subtree
	while (node = walker.nextNode()) {
		yield node;
	}
}



const fromSelectSptionsToNestedFind = {
	id: function(id) { walkElements(this).find(el => el.id === id) },
	className: function(className) {}
};

export function elementReady(arg1, context = document.body, checkFirst = true) {
	let resolve,reject;
	var p = Promise((O,X)=>(resolve=O,reject=X));
	p.resolve=resolve;
	p.reject=reject;


	// Normalize arguments
	let checkMatch;
	let checkOptions;
	let selector;

	if (typeof arg1 === "string") {
		selector = arg1;
		checkMatch = el => el.querySelector(selector);
	} else if (typeof arg1 === 'function') {
		checkMatch = arg1;
	} else if (typeof arg1 === 'oject') {
		checkOptions = arg1
		selector = checkOptions.selector || (
			checkOptions.className
		);
		checkMatch = el => checkMatchFast(el, checkOptions);
	} else throw new Error(2);

	// 1. Check immediately
	if (checkFirst) {
		if (matchArgs.selector) {
			const initial = context.querySelector(matchArgs.selector);
			if (initial) {
				return resolve(initial);
			}
		} else {
			 for (let el of context.all) {
				if (checkMatch(el, matchArgs))
			 }
		}
	}

	// 2. Observe DOM mutations
	const observer = new MutationObserver((mutationRecords) => {
		for (const record of mutationRecords) {
			for (const node of record.addedNodes) {
				if (!(node instanceof Element)) continue;

				// Direct match
				if (checkMatch(node, matchArgs)) {
					observer.disconnect();
					return resolve(node);
				}

				// Match inside subtree
				const found = node.querySelector(matchArgs.selector || "*");
				if (found && checkMatch(found, matchArgs)) {
					observer.disconnect();
					return resolve(found);
				}
			}
		}
	});

	observer.observe(document.documentElement, {
		childList: true,
		subtree: true
	});

	p.then(() => observer.disconnect());

	return p;
}

