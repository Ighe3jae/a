# TODO: add script for this
( set -eux
	custom_path="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings"
	custom_binding="org.gnome.settings-daemon.plugins.media-keys.custom-keybinding"
	settings_schema="org.gnome.settings-daemon.plugins.media-keys"

	for index in {0..8}; do
		workspace=$((index + 1))
		binding_path="$custom_path/custom${index}/" #TODO REMOVE me from settings
		##binding_path="$custom_path/gnome-move-window-to-workspace-${index}/"
		##gsettings set $custom_binding:"$binding_path" name "Move to workspace $workspace"
		gsettings set $custom_binding:"$binding_path" command "$HOME/.local/bin/gnome-move-window-to-workspace $index"
		##gsettings set $custom_binding:"$binding_path" binding "<Super><Shift>$workspace"
	done

	# Get existing keybindings
	existing_keybindings=$(gsettings get $settings_schema custom-keybindings)
	
	# Build new keybindings array
	keybindings_list=""
	for index in {0..8}; do
		keybindings_list="${keybindings_list}'$custom_path/custom${index}/',"
	done
	keybindings_list="${keybindings_list%,}"

	# Merge existing with new
	if [ "$existing_keybindings" != "@as []" ]; then
		existing_keybindings=${existing_keybindings#'['}
		existing_keybindings=${existing_keybindings%']'}
		existing_keybindings=${existing_keybindings%["$IFS" 	]}
		existing_keybindings=${existing_keybindings%["$IFS" 	]}
		existing_keybindings=${existing_keybindings%["$IFS"]} # IDK, just in case
		existing_keybindings=${existing_keybindings%','}
		keybindings_list="$existing_keybindings${existing_keybindings+,} $keybindings_list"
	fi

	gsettings set $settings_schema custom-keybindings "[$keybindings_list]"
)






